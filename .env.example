# Backend Configuration Example
# Üretim ortamı için bu dosyayı .env olarak kopyalayın ve değerleri güncelleyin
FLASK_ENV=development
FLASK_DEBUG=True

# Security - JWT Configuration
# UYARI: Üretim ortamında güçlü bir secret key kullanın!
JWT_SECRET_KEY=your-secret-key-here-change-in-production
JWT_ACCESS_TOKEN_EXPIRES_HOURS=2

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/

# API Configuration
API_HOST=127.0.0.1
API_PORT=5000

# CORS Configuration
# Üretim ortamında uygun domain'leri girin
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_DAY=500
RATE_LIMIT_PER_HOUR=100
